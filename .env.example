# Server Configuration
PORT=5000
NODE_ENV=development
HOST=0.0.0.0

# Frontend Configuration (Vite)
VITE_API_BASE_URL=http://localhost:5000/api

# Database Configuration (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=investiq
DB_PORT=3306

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_me_in_production
JWT_EXPIRES_IN=7d
RESET_OTP_EXPIRES_MINUTES=10

# EmailJS OTP Password Reset
# Create an EmailJS service/template and use these template variables:
# to_email, to_name, username, otp, expires_minutes, app_name
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key_optional

# AI Models & Providers
# Set default provider: 'gemini' or 'openai'
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# Third-Party Market Data & Search APIs
# Tavily Search API (for agentic web searches)
TAVILY_API_KEY=your_tavily_api_key
# Yahoo Finance API (falls back to web scraping / mock data if not set)
YAHOO_FINANCE_API_KEY=your_yahoo_finance_api_key
# News API (for news aggregation)
NEWS_API_KEY=your_news_api_key
# AlphaVantage API (for company financials)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key



