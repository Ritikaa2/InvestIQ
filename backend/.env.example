PORT=5000
HOST=0.0.0.0
NODE_ENV=development

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=investiq
DB_PORT=3306

JWT_SECRET=your_jwt_secret_key_change_me_in_production
JWT_EXPIRES_IN=7d
RESET_OTP_EXPIRES_MINUTES=10

# Gmail OTP password reset. Use a Gmail app password, not your normal password.
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password
EMAIL_FROM=InvestIQ <your_email@gmail.com>

# Optional generic SMTP alternative
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
TAVILY_API_KEY=your_tavily_api_key
YAHOO_FINANCE_API_KEY=your_yahoo_finance_api_key
NEWS_API_KEY=your_news_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key
